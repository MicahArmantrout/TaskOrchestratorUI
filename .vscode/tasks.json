{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
    ,
    {
      "label": "tsc: watch",
      "type": "shell",
      "command": "npx tsc -w -p tsconfig.app.json",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "dev:all",
      "dependsOn": ["npm: dev", "tsc: watch"],
      "dependsOrder": "parallel",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
